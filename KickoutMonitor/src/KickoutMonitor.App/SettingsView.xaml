<UserControl x:Class="KickoutMonitor.App.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F5F7">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBackground}" Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Content="Back" Click="BackButton_Click" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Settings" Foreground="White" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="VisionMaster local configuration" Foreground="#C8D1DA" FontSize="12"/>
                </StackPanel>
                <Button Grid.Column="2" Content="Reload" Command="{Binding ReloadCommand}" VerticalAlignment="Center"/>
                <Button Grid.Column="3" Content="Reset Defaults" Command="{Binding ResetCommand}" VerticalAlignment="Center"/>
                <Button Grid.Column="4" Content="Save" Command="{Binding SaveCommand}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom" Background="#E1E5E9">
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap"/>
        </StatusBar>

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Settings file" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding SettingsPath}" IsReadOnly="True" BorderThickness="0" Background="Transparent"/>
                    <TextBlock Text="Edit JSON values carefully. Save validates the file before writing. Current workflows use the loaded settings at startup and for future module actions." Foreground="#52606D" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <TextBox Grid.Row="1"
                     Text="{Binding SettingsJson, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="13"
                     TextWrapping="NoWrap"/>
        </Grid>
    </DockPanel>
</UserControl>
