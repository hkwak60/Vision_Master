<UserControl x:Class="KickoutMonitor.App.IrsReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F5F7"
             Focusable="True"
             PreviewKeyDown="IrsReviewView_PreviewKeyDown">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBackground}" Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Content="Back" Click="BackButton_Click"
                        VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="IRS Review" Foreground="White"
                               FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="Prototype raw image review from IRS workbook"
                               Foreground="#C8D1DA" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom" Background="#E1E5E9">
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap"/>
        </StatusBar>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="78"/>
                <RowDefinition Height="105"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="1" Padding="12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="IRS workbook" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding WorkbookPath, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True" Height="34"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Browse"
                            Command="{Binding BrowseCommand}" VerticalAlignment="Bottom"/>
                    <Button Grid.Column="2" Content="Load IRS Queue"
                            Command="{Binding LoadCommand}" VerticalAlignment="Bottom"/>
                    <Button Grid.Column="3" Content="Generate Dataset"
                            Command="{Binding GenerateDatasetCommand}" VerticalAlignment="Bottom"/>
                    <Button Grid.Column="4" Content="Summary Report"
                            Command="{Binding SummaryReportCommand}" VerticalAlignment="Bottom"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#18212A" BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="1" Padding="8" Margin="0,0,0,10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Activity Log"
                               Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ListBox x:Name="ActivityLogList" ItemsSource="{Binding ActivityLog}" Background="#18212A"
                             Foreground="#D9E2EC" BorderThickness="0"
                             FontFamily="Consolas" FontSize="12"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </DockPanel>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="410"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource PanelBorder}"
                        BorderThickness="1" Margin="0,0,10,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="12,10" BorderBrush="{StaticResource PanelBorder}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="IRS Review Queue" FontSize="16" FontWeight="SemiBold"/>
                        </Border>
                        <DataGrid ItemsSource="{Binding Candidates}" SelectedItem="{Binding SelectedCandidate}"
                                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  SelectionMode="Single"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ReviewStatus}" Value="Saved">
                                            <Setter Property="Background" Value="#D9EAD3"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ReviewStatus}" Value="Saved with missing">
                                            <Setter Property="Background" Value="#FFF2CC"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ReviewStatus}" Value="Copying">
                                            <Setter Property="Background" Value="#CFE2F3"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ReviewStatus}" Value="Copy failed">
                                            <Setter Property="Background" Value="#F4CCCC"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="66"/>
                                <DataGridTextColumn Header="Line" Binding="{Binding LinePolarity}" Width="68"/>
                                <DataGridTextColumn Header="Cell ID" Binding="{Binding CellId}" Width="112"/>
                                <DataGridTextColumn Header="Vision Type" Binding="{Binding VisionType}" Width="112"/>
                                <DataGridTextColumn Header="Camera" Binding="{Binding Camera}" Width="70"/>
                                <DataGridTextColumn Header="2nd Result" Binding="{Binding SecondResult}" Width="80"/>
                                <DataGridTextColumn Header="2nd Reason" Binding="{Binding SecondReason}" Width="170"/>
                                <DataGridTextColumn Header="Review" Binding="{Binding ReviewStatus}" Width="95"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Background="#111820" BorderBrush="{StaticResource PanelBorder}"
                        BorderThickness="1" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="#EEF1F4" Padding="8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding CurrentPreview.Label}"
                                           Foreground="#243B53" FontWeight="SemiBold"/>
                                <TextBlock Text="  |  " Foreground="#829AB1"/>
                                <TextBlock Text="{Binding ImagePositionText}" Foreground="#52606D"/>
                            </StackPanel>
                        </Border>
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollViewer x:Name="ImageScrollViewer"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          PanningMode="Both"
                                          CanContentScroll="False"
                                          PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel"
                                          PreviewMouseLeftButtonDown="ImageScrollViewer_PreviewMouseLeftButtonDown"
                                          PreviewMouseLeftButtonUp="ImageScrollViewer_PreviewMouseLeftButtonUp"
                                          PreviewMouseMove="ImageScrollViewer_PreviewMouseMove"
                                          LostMouseCapture="ImageScrollViewer_LostMouseCapture"
                                          Cursor="Hand"
                                          Background="#111820">
                                <Grid MinWidth="200" MinHeight="200">
                                    <Image x:Name="ReviewImage"
                                           Source="{Binding CurrentPreview.Image, NotifyOnTargetUpdated=True}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TargetUpdated="ReviewImage_TargetUpdated">
                                        <Image.LayoutTransform>
                                            <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                                        </Image.LayoutTransform>
                                    </Image>
                                    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                            Margin="10" Padding="8,5" Background="#CC111820"
                                            CornerRadius="4">
                                        <TextBlock Text="{Binding ReasonOverlay}" Foreground="White"
                                                   FontWeight="SemiBold" TextWrapping="Wrap"
                                                   MaxWidth="420"/>
                                    </Border>
                                    <TextBlock Text="{Binding CurrentPreview.State}"
                                               Foreground="#D9E2EC" FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </ScrollViewer>
                            <Border Grid.Row="1" Background="#18212A" Padding="8">
                                <Grid>
                                    <TextBlock Text="Drag or scroll: pan   Ctrl + scroll: zoom at pointer"
                                               Foreground="#9FB3C8" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="ZoomText" Text="60%"
                                               Foreground="White" FontWeight="SemiBold"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource PanelBorder}"
                        BorderThickness="1" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False"
                                  PanningMode="VerticalOnly">
                    <StackPanel>
                        <StackPanel.Resources>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Margin" Value="2"/>
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="MinHeight" Value="27"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="BorderBrush" Value="#BCCCDC"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="3"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Background" Value="#CFE2F3"/>
                                                    <Setter Property="BorderBrush" Value="#3D85C6"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#627D98"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </StackPanel.Resources>
                        <TextBlock Text="{Binding SelectionPanelTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding FinalClassOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton Content="{Binding DisplayName}"
                                                  ToolTip="{Binding ToolTip}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Separator Margin="0,6"/>
                        <TextBlock Text="IRS Selection" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding TopClassifications}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton Content="{Binding DisplayName}"
                                                  ToolTip="{Binding ToolTip}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding ASelections}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton Content="{Binding DisplayName}"
                                                  ToolTip="{Binding ToolTip}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding BSelections}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton Content="{Binding DisplayName}"
                                                  ToolTip="{Binding ToolTip}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="(Micro)" Foreground="#52606D" FontWeight="SemiBold" Margin="2,4,0,0"/>
                        <ItemsControl ItemsSource="{Binding MicroSelections}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="5"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton Content="{Binding DisplayName}"
                                                  ToolTip="{Binding ToolTip}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding TabsideSelections}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton Content="{Binding DisplayName}"
                                                  ToolTip="{Binding ToolTip}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding GapSelections}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton Content="{Binding DisplayName}"
                                                  ToolTip="{Binding ToolTip}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding SepaSelections}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton Content="{Binding DisplayName}"
                                                  ToolTip="{Binding ToolTip}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding SepaShoulderSelections}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton Content="{Binding DisplayName}"
                                                  ToolTip="{Binding ToolTip}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="Enter: Commit Selection"
                                Command="{Binding CommitCommand}"
                                Margin="2,6,2,8"
                                Padding="8,5"/>
                        <Separator/>
                        <TextBlock Text="IRS Row" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,8"/>
                        <TextBlock Text="Cell ID" Foreground="#52606D"/>
                        <TextBlock Text="{Binding SelectedCandidate.CellId}" FontWeight="SemiBold"
                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <TextBlock Text="2nd reason" Foreground="#52606D"/>
                        <TextBlock Text="{Binding SelectedCandidate.SecondReason}" FontWeight="SemiBold"
                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <TextBlock Text="Image state" Foreground="#52606D"/>
                        <TextBlock Text="{Binding SelectedCandidate.ImageState}" FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Review" Foreground="#52606D"/>
                        <TextBlock Text="{Binding SelectedCandidate.ReviewStatus}" FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <Separator/>
                        <TextBlock Text="Image Navigation" FontWeight="SemiBold" Margin="0,10,0,4"/>
                        <UniformGrid Columns="2">
                            <Button Content="Left: Previous" Command="{Binding PreviousImageCommand}"/>
                            <Button Content="Right: Next" Command="{Binding NextImageCommand}"/>
                        </UniformGrid>
                        <TextBlock Text="Cell Navigation" FontWeight="SemiBold" Margin="0,10,0,4"/>
                        <UniformGrid Columns="2">
                            <Button Content="Up: Previous" Command="{Binding PreviousCommand}"/>
                            <Button Content="Down: Next" Command="{Binding NextCommand}"/>
                        </UniformGrid>
                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>

