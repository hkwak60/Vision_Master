<UserControl x:Class="KickoutMonitor.App.NgBypassMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F5F7"
             Focusable="True">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBackground}" Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Content="Back" Click="BackButton_Click"
                        VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="NG/Bypass Monitor" Foreground="White"
                               FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="Measure-based NG and BYPASS_NG review"
                               Foreground="#C8D1DA" FontSize="12"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding PositionText}" Foreground="White"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom" Background="#E1E5E9">
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap"/>
        </StatusBar>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="92"/>
                <RowDefinition Height="105"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="White" BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="1" Padding="8" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="385"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Lines / Polarities" FontWeight="SemiBold"/>
                        <ListBox ItemsSource="{Binding MachineOptions}" Height="48"
                                 BorderBrush="{StaticResource PanelBorder}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}"
                                              Content="{Binding Label}"
                                              Margin="7,2" MinWidth="78"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Start date" FontWeight="SemiBold"/>
                        <DatePicker SelectedDate="{Binding StartDate}" Height="34"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="End date" FontWeight="SemiBold"/>
                        <DatePicker SelectedDate="{Binding EndDate}" Height="34"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,10,0">
                        <TextBlock Text="Measure" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Measure, UpdateSourceTrigger=PropertyChanged}" Height="34"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" Margin="0,0,10,0">
                        <TextBlock Text="Filter" FontWeight="SemiBold"/>
                        <WrapPanel Margin="0,4,0,0">
                            <CheckBox Content="UPPER" IsChecked="{Binding IncludeUpper}" Margin="0,0,10,0"/>
                            <CheckBox Content="LOWER" IsChecked="{Binding IncludeLower}" Margin="0,0,10,0"/>
                            <CheckBox Content="Bypassed" IsChecked="{Binding Bypassed}" Margin="0,0,10,0"/>
                            <CheckBox Content="Skip NG" IsEnabled="{Binding Bypassed}" IsChecked="{Binding SkipNg}"/>
                        </WrapPanel>
                    </StackPanel>
                    <Button Grid.Column="5" Content="Load Queue"
                            Command="{Binding LoadCommand}" VerticalAlignment="Bottom"/>
                    <StackPanel Grid.Column="6" Margin="16,0,10,0">
                        <TextBlock Text="Report date" FontWeight="SemiBold"/>
                        <DatePicker SelectedDate="{Binding ReportDate}" Height="34"/>
                    </StackPanel>
                    <Button Grid.Column="7" Content="Generate Summary"
                            Command="{Binding GenerateReportCommand}" VerticalAlignment="Bottom"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#18212A" BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="1" Padding="8" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Activity Log"
                                   Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ListBox x:Name="ActivityLogList" ItemsSource="{Binding ActivityLog}" Background="#18212A"
                                 Foreground="#D9E2EC" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="12"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                    <DockPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock DockPanel.Dock="Top" Text="Summary"
                                   Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <DataGrid ItemsSource="{Binding SummaryRows}"
                                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  Background="#F8FAFC" BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Line" Binding="{Binding LinePolarity}" Width="76"/>
                                <DataGridTextColumn Header="Measure" Binding="{Binding Measure}" Width="90"/>
                                <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="70"/>
                                <DataGridTextColumn Header="Target" Binding="{Binding TargetValue}" Width="88"/>
                                <DataGridTextColumn Header="Initial" Binding="{Binding InitialMatched}" Width="70"/>
                                <DataGridTextColumn Header="Real" Binding="{Binding Real}" Width="58"/>
                                <DataGridTextColumn Header="Overkill" Binding="{Binding Overkill}" Width="75"/>
                                <DataGridTextColumn Header="Real Rate" Binding="{Binding RealRate, StringFormat=P2}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="390"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource PanelBorder}"
                        BorderThickness="1" Margin="0,0,10,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="12,10" BorderBrush="{StaticResource PanelBorder}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="NG/Bypass Queue" FontSize="16" FontWeight="SemiBold"/>
                        </Border>
                        <DataGrid ItemsSource="{Binding Candidates}" SelectedItem="{Binding SelectedCandidate}"
                                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  SelectionMode="Single"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Decision}" Value="RealNg">
                                            <Setter Property="Background" Value="#D9EAD3"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Decision}" Value="Overkill">
                                            <Setter Property="Background" Value="#F4CCCC"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="66"/>
                                <DataGridTextColumn Header="Line" Binding="{Binding LinePolarity}" Width="68"/>
                                <DataGridTextColumn Header="Cell ID" Binding="{Binding CellId}" Width="112"/>
                                <DataGridTextColumn Header="Measure" Binding="{Binding Measure}" Width="92"/>
                                <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="64"/>
                                <DataGridTextColumn Header="Review" Binding="{Binding ReviewLabel}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Background="#111820" BorderBrush="{StaticResource PanelBorder}"
                        BorderThickness="1" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="#EEF1F4" Padding="8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding CurrentPreview.Label}"
                                           Foreground="#243B53" FontWeight="SemiBold"/>
                                <TextBlock Text="  |  " Foreground="#829AB1"/>
                                <TextBlock Text="{Binding ImagePositionText}" Foreground="#52606D"/>
                            </StackPanel>
                        </Border>
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollViewer x:Name="ImageScrollViewer"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          PanningMode="Both"
                                          CanContentScroll="False"
                                          PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel"
                                          PreviewMouseLeftButtonDown="ImageScrollViewer_PreviewMouseLeftButtonDown"
                                          PreviewMouseLeftButtonUp="ImageScrollViewer_PreviewMouseLeftButtonUp"
                                          PreviewMouseMove="ImageScrollViewer_PreviewMouseMove"
                                          LostMouseCapture="ImageScrollViewer_LostMouseCapture"
                                          Cursor="Hand"
                                          Background="#111820">
                                <Grid MinWidth="200" MinHeight="200">
                                    <Image x:Name="ReviewImage"
                                           Source="{Binding CurrentPreview.Image, NotifyOnTargetUpdated=True}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TargetUpdated="ReviewImage_TargetUpdated">
                                        <Image.LayoutTransform>
                                            <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                                        </Image.LayoutTransform>
                                    </Image>
                                    <TextBlock Text="{Binding CurrentPreview.State}"
                                               Foreground="#D9E2EC" FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <Button Content="⚑"
                                            Command="{Binding FlagCommand}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="10"
                                            Padding="8,4"
                                            ToolTip="Flag this cell for follow-up"/>
                                </Grid>
                            </ScrollViewer>
                            <Border Grid.Row="1" Background="#18212A" Padding="8">
                                <Grid>
                                    <TextBlock Text="Drag or scroll: pan   Ctrl + scroll: zoom at pointer"
                                               Foreground="#9FB3C8" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="ZoomText" Text="60%"
                                               Foreground="White" FontWeight="SemiBold"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource PanelBorder}"
                        BorderThickness="1" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Classification" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Button Content="Real  [R]" Command="{Binding RealCommand}" Background="#D9EAD3"/>
                            <Button Content="Overkill  [O]" Command="{Binding OverkillCommand}" Background="#FCE5CD"/>
                            <Separator Margin="0,10,0,0"/>
                            <TextBlock Text="Cell ID" Foreground="#52606D" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding SelectedCandidate.CellId}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock Text="Inspection time" Foreground="#52606D" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding SelectedCandidate.Candidate.InspectedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Measure / Side" Foreground="#52606D" Margin="0,10,0,0"/>
                            <TextBlock FontWeight="SemiBold">
                                <Run Text="{Binding SelectedCandidate.Measure, Mode=OneWay}"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding SelectedCandidate.Side, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Text="Target" Foreground="#52606D" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding SelectedCandidate.TargetValue}" FontWeight="SemiBold"/>
                            <TextBlock Text="Copy state" Foreground="#52606D" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding SelectedCandidate.CopyState}" FontWeight="SemiBold"/>
                            <Separator Margin="0,10,0,0"/>
                            <TextBlock Text="Image Navigation" FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <UniformGrid Columns="2">
                                <Button Content="Left: Previous" Command="{Binding PreviousImageCommand}"/>
                                <Button Content="Right: Next" Command="{Binding NextImageCommand}"/>
                            </UniformGrid>
                            <TextBlock Text="Cell Navigation" FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <UniformGrid Columns="2">
                                <Button Content="Up: Previous" Command="{Binding PreviousCommand}"/>
                                <Button Content="Down: Next" Command="{Binding NextCommand}"/>
                            </UniformGrid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
