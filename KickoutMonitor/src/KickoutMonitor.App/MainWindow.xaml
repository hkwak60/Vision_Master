<Window x:Class="KickoutMonitor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VisionMaster"
        Width="1500" Height="920" MinWidth="1100" MinHeight="700"
        Background="#F3F5F7">
    <DockPanel>
        <Border x:Name="ShellHeader" DockPanel.Dock="Top" Background="{StaticResource HeaderBackground}" Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="TitleText" Text="VisionMaster" Foreground="White"
                               FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SubtitleText" Text="Select a review tool"
                               Foreground="#C8D1DA" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="DashboardPanel" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Click="KickoutButton_Click" Margin="16"
                    FontSize="24" FontWeight="SemiBold">
                <StackPanel>
                    <TextBlock Text="KickoutMonitor" HorizontalAlignment="Center"/>
                    <TextBlock Text="Welding NG / overkill review"
                               FontSize="13" FontWeight="Normal"
                               Foreground="#52606D" HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="1" Click="IrsButton_Click" Margin="16"
                    FontSize="24" FontWeight="SemiBold">
                <StackPanel>
                    <TextBlock Text="IRS Review" HorizontalAlignment="Center"/>
                    <TextBlock Text="Prototype raw image review from IRS workbook"
                               FontSize="13" FontWeight="Normal"
                               Foreground="#52606D" HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Button>
        </Grid>

        <ContentControl x:Name="ModuleHost" Visibility="Collapsed"/>
    </DockPanel>
</Window>
