<UserControl x:Class="KickoutMonitor.App.FlaggedReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F3F5F7" Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="130"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource HeaderBackground}" Padding="14" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Content="Back" Click="BackButton_Click" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Flagged" Foreground="White" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Status}" Foreground="#C8D1DA" FontSize="12"/>
                </StackPanel>
                <Button Grid.Column="2" Content="Load Flagged Queue" Command="{Binding LoadFlaggedCommand}" Margin="8,0,0,0"/>
                <Button Grid.Column="3" Content="Previously Flagged" Command="{Binding LoadPreviousCommand}" Margin="8,0,0,0"/>
                <Button Grid.Column="4" Content="Generate Dataset" Command="{Binding GenerateDatasetCommand}" Margin="8,0,0,0"/>
                <Button Grid.Column="5" Content="Generate Summary" Command="{Binding GenerateSummaryCommand}" Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1.45*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="1" Padding="8" Margin="0,0,10,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Queue" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding PositionText}" Margin="12,2,0,0" Foreground="#52606D"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Candidates}"
                              SelectedItem="{Binding SelectedCandidate, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="70"/>
                            <DataGridTextColumn Header="Line" Binding="{Binding LinePolarity}" Width="80"/>
                            <DataGridTextColumn Header="Cell" Binding="{Binding CellId}" Width="150"/>
                            <DataGridTextColumn Header="Side" Binding="{Binding Camera}" Width="60"/>
                            <DataGridTextColumn Header="Reason" Binding="{Binding SecondReason}" Width="*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding ReviewStatus}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="#111820" BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="1" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#EEF1F4" Padding="8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding CurrentPreview.Label}" Foreground="#243B53" FontWeight="SemiBold"/>
                            <TextBlock Text="  |  " Foreground="#829AB1"/>
                            <TextBlock Text="{Binding ImagePositionText}" Foreground="#52606D"/>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ScrollViewer x:Name="ImageScrollViewer"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      PanningMode="Both"
                                      CanContentScroll="False"
                                      PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel"
                                      PreviewMouseLeftButtonDown="ImageScrollViewer_PreviewMouseLeftButtonDown"
                                      PreviewMouseLeftButtonUp="ImageScrollViewer_PreviewMouseLeftButtonUp"
                                      PreviewMouseMove="ImageScrollViewer_PreviewMouseMove"
                                      LostMouseCapture="ImageScrollViewer_LostMouseCapture"
                                      Cursor="Hand"
                                      Background="#111820">
                            <Grid MinWidth="200" MinHeight="200">
                                <Image x:Name="ReviewImage"
                                       Source="{Binding CurrentPreview.Image, NotifyOnTargetUpdated=True}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TargetUpdated="ReviewImage_TargetUpdated">
                                    <Image.LayoutTransform>
                                        <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                                    </Image.LayoutTransform>
                                </Image>
                                <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                        Margin="10" Padding="8,5" Background="#CC111820"
                                        CornerRadius="4">
                                    <TextBlock Text="{Binding ReasonOverlay}" Foreground="White"
                                               FontWeight="SemiBold" TextWrapping="Wrap"
                                               MaxWidth="420"/>
                                </Border>
                                <TextBlock Text="{Binding CurrentPreview.State}"
                                           Foreground="#D9E2EC" FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </ScrollViewer>
                        <Border Grid.Row="1" Background="#18212A" Padding="8">
                            <Grid>
                                <TextBlock Text="Drag or scroll: pan   Ctrl + scroll: zoom at pointer"
                                           Foreground="#9FB3C8" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="ZoomText" Text="60%"
                                           Foreground="White" FontWeight="SemiBold"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="1" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <StackPanel.Resources>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Margin" Value="2"/>
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="MinHeight" Value="27"/>
                                <Setter Property="FontSize" Value="12"/>
                            </Style>
                        </StackPanel.Resources>
                        <TextBlock Text="{Binding SelectionPanelTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <StackPanel Visibility="{Binding FinalClassVisibility}">
                            <ItemsControl ItemsSource="{Binding FinalClassOptions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><UniformGrid Columns="1"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ToggleButton Content="{Binding DisplayName}"
                                                      ToolTip="{Binding ToolTip}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <StackPanel Visibility="{Binding FirstStageSelectionVisibility}">
                            <ItemsControl ItemsSource="{Binding TopClassifications}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate><ToggleButton Content="{Binding DisplayName}" ToolTip="{Binding ToolTip}" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/></DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Crop" Foreground="#52606D" FontWeight="SemiBold" Margin="2,8,0,0"/>
                            <ItemsControl ItemsSource="{Binding ASelections}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate><DataTemplate><ToggleButton Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/></DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding BSelections}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate><DataTemplate><ToggleButton Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/></DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding MicroSelections}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="5"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate><DataTemplate><ToggleButton Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/></DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding TabsideSelections}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate><DataTemplate><ToggleButton Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/></DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding GapSelections}">
                                <ItemsControl.ItemTemplate><DataTemplate><ToggleButton Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/></DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding SepaSelections}">
                                <ItemsControl.ItemTemplate><DataTemplate><ToggleButton Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/></DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding SepaShoulderSelections}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate><DataTemplate><ToggleButton Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/></DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <Button Content="Enter: Commit Selection" Command="{Binding CommitCommand}" Margin="2,8,2,8"/>
                        <Separator Margin="0,6"/>
                        <UniformGrid Columns="2">
                            <Button Content="Left: Previous" Command="{Binding PreviousImageCommand}"/>
                            <Button Content="Right: Next" Command="{Binding NextImageCommand}"/>
                            <Button Content="Up: Previous" Command="{Binding PreviousCommand}"/>
                            <Button Content="Down: Next" Command="{Binding NextCommand}"/>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1" Padding="8" Margin="0,10,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Activity" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ListBox x:Name="ActivityLogList" ItemsSource="{Binding ActivityLog}"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
